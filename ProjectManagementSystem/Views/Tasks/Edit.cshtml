@model ProjectManagementSystem.ViewModels.Tasks.EditTaskViewModel

@{
    ViewData["Title"] = "Edit Task";
}

<h2>Edit Task</h2>

<form asp-action="Edit" method="post" class="mt-3">
    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type" asp-items="Html.GetEnumSelectList<ProjectManagementSystem.Enums.TaskType>()" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Priority" class="form-label"></label>
        <select asp-for="Priority" asp-items="Html.GetEnumSelectList<ProjectManagementSystem.Enums.TaskPriority>()" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<ProjectManagementSystem.Enums.ProjectTaskStatus>()" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Deadline" class="form-label"></label>
        <input asp-for="Deadline" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="AssigneeId" class="form-label">Assignee</label>
        <select asp-for="AssigneeId" asp-items="Model.Users" class="form-select">
            <option value="">-- Select Assignee --</option>
        </select>
        <span asp-validation-for="AssigneeId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" asp-route-projectId="@Context.GetRouteValue("projectId")" class="btn btn-outline-secondary">Cancel</a>
</form>