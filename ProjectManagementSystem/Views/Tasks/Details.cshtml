@model ProjectManagementSystem.ViewModels.Tasks.TaskDetailsViewModel
@using ProjectManagementSystem.Helpers

@{
    ViewData["Title"] = Model.Tag;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>
        <partial name="_TaskTag" model="Model" /> - @Model.Title
    </h2>
    <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-outline-secondary">Back to Tasks</a>
</div>

<dl class="row">
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Type</dt>
    <dd class="col-sm-10">@Model.Type</dd>
    <dt class="col-sm-2">Priority</dt>
    <dd class="col-sm-10">@Model.Priority</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status.GetDisplayName()</dd>
    <dt class="col-sm-2">Deadline</dt>
    <dd class="col-sm-10">@(Model.Deadline?.ToString("dd MMM yyyy") ?? "-")</dd>
    <dt class="col-sm-2">Reporter</dt>
    <dd class="col-sm-10">@Model.ReporterName</dd>
    <dt class="col-sm-2">Assignee</dt>
    <dd class="col-sm-10">@(Model.AssigneeName ?? "Unassigned")</dd>
</dl>

<hr />

<h4>Time Logs <small class="text-muted fs-6">Total: @Model.FormattedTotalHours</small></h4>

<form asp-controller="TimeLogs" asp-action="Create" method="post" class="mb-4">
    <input type="hidden" name="TaskId" value="@Model.Id" />
    <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label">Days</label>
            <input type="number" name="Days" min="0" max="99" value="0" class="form-control" style="width:80px" />
        </div>
        <div class="col-auto">
            <label class="form-label">Hours</label>
            <input type="number" name="Hours" min="0" max="23" value="0" class="form-control" style="width:80px" />
        </div>
        <div class="col-auto">
            <label class="form-label">Minutes</label>
            <input type="number" name="Minutes" min="0" max="59" value="0" class="form-control" style="width:80px" />
        </div>
        <div class="col-auto">
            <label class="form-label">Date</label>
            <input type="date" name="Date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col">
            <label class="form-label">Description</label>
            <input type="text" name="Description" class="form-control" placeholder="Optional..." />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Log Time</button>
        </div>
    </div>
</form>

@if (!Model.TimeLogs.Any())
{
    <p class="text-muted">No time logged yet.</p>
}
else
{
    @foreach (var log in Model.TimeLogs)
    {
        <div class="card mb-2">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <strong>@log.FormattedHours</strong> - @log.Date.ToString("dd MMM yyyy")
                    @if (!string.IsNullOrEmpty(log.Description))
                    {
                        <span class="text-muted"> - @log.Description</span>
                    }
                    <br />
                    <small class="text-muted">@log.UserName</small>
                </div>
                @if (log.CanEdit)
                {
                    <form asp-controller="TimeLogs" asp-action="Delete" asp-route-id="@log.Id" asp-route-projectId="@Model.ProjectId" method="post">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                }
            </div>
        </div>
    }
}

<hr />

<h4>Comments</h4>

<form asp-controller="Comments" asp-action="Create" method="post" class="mb-4">
    <input type="hidden" name="TaskId" value="@Model.Id" />
    <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
    <div class="mb-3">
        <textarea name="Content" class="form-control" rows="3" placeholder="Add a comment..."></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Add Comment</button>
</form>

@if (!Model.Comments.Any())
{
    <p class="text-muted">No comments yet.</p>
}
else
{
    @foreach (var comment in Model.Comments)
    {
        <div class="card mb-2">
            <div class="card-body">
                <p>@comment.Content</p>
                <small class="text-muted">@comment.AuthorName - @comment.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                @if (comment.CanEdit)
                {
                    <div class="mt-2">
                        <a asp-controller="Comments" asp-action="Edit" asp-route-id="@comment.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-controller="Comments" asp-action="Delete" asp-route-id="@comment.Id" asp-route-projectId="@Model.ProjectId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
}