@model ProjectManagementSystem.ViewModels.Tasks.TaskDetailsViewModel

@{
    ViewData["Title"] = "Delete Task";
}

<h2>Delete Task</h2>

<p class="text-danger">Are you sure you want to delete this task?</p>

<dl class="row mt-3">
    <dt class="col-sm-2">Tag</dt>
    <dd class="col-sm-10">@Model.Tag</dd>
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Type</dt>
    <dd class="col-sm-10">@Model.Type</dd>
    <dt class="col-sm-2">Priority</dt>
    <dd class="col-sm-10">@Model.Priority</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>
    <dt class="col-sm-2">Deadline</dt>
    <dd class="col-sm-10">@(Model.Deadline?.ToString("dd MMM yyyy") ?? "-")</dd>
    <dt class="col-sm-2">Assignee</dt>
    <dd class="col-sm-10">@Model.AssigneeName</dd>
</dl>

<form asp-action="Delete" asp-route-projectId="@Context.GetRouteValue("projectId")" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" asp-route-projectId="@Context.GetRouteValue("projectId")" class="btn btn-outline-secondary">Cancel</a>
</form>