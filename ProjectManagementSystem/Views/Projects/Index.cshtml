@model IEnumerable<ProjectManagementSystem.ViewModels.Projects.ProjectListViewModel>
@using ProjectManagementSystem.Constants

@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Projects</h2>
    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Manager))
    {
        <a asp-action="Create" class="btn btn-primary">+ New Project</a>
    }
</div>

@if (!Model.Any())
{
    <p class="text-muted">No projects yet. Create your first one!</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Tag</th>
                <th>Name</th>
                <th>Description</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model)
            {
                <tr>
                    <td>
                        <partial name="_ProjectTag" model="@project.Tag" />
                    </td>
                    <td>@project.Name</td>
                    <td>@project.Description</td>
                    <td>@project.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Manager))
                        {
                            <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    onclick="confirmDelete('@Url.Action("DeleteConfirmed", "Projects", new { id = project.Id })', '@project.Name', 'project')">
                                Delete
                            </button>
                        }
                        <a asp-controller="Tasks" asp-action="Index" asp-route-projectId="@project.Id" class="btn btn-sm btn-outline-primary">View Tasks</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}