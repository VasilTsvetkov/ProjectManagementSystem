@model ProjectManagementSystem.ViewModels.Projects.ProjectDetailsViewModel

@{
    ViewData["Title"] = "Delete Project";
}

<h2>Delete Project</h2>

<p class="text-danger">Are you sure you want to delete this project?</p>

<dl class="row mt-3">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Tag</dt>
    <dd class="col-sm-10">@Model.Tag</dd>
    <dt class="col-sm-2">Created At</dt>
    <dd class="col-sm-10">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>