@model ProjectManagementSystem.ViewModels.Comments.CommentViewModel

@{
    ViewData["Title"] = "Edit Comment";
}

<h2>Edit Comment</h2>

<form asp-action="Edit" method="post" class="mt-3">
    <input type="hidden" asp-for="TaskId" />
    <div class="mb-3">
        <label asp-for="Content" class="form-label"></label>
        <textarea asp-for="Content" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-controller="Tasks" asp-action="Details" asp-route-id="@Model.TaskId" class="btn btn-outline-secondary">Cancel</a>
</form>